msgstr "مصادقة الجهاز"

#: ../properties/nm-l2tp-dialog.ui.h:32
msgid ""
"Pre-shared key (PSK) secret.\n"
"config: ipsec-psk"
msgstr ""
"سر المفتاح المسبق المشاركة (PSK).\n"
"config: ipsec-psk"

