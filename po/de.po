msgstr "l2tp-Objekt konnte nicht erzeugt werden."

#: properties/nm-l2tp-editor.c:850
msgid "could not load UI widget"
msgstr "UI-Widget konnte nicht geladen werden"

#: properties/nm-l2tp-editor-plugin.c:17
msgid "Layer 2 Tunneling Protocol (L2TP)"
msgstr "Layer-2-Tunneling-Protokoll (L2TP)"

#: properties/nm-l2tp-editor-plugin.c:18
msgid "Compatible with Microsoft and other L2TP VPN servers."
msgstr "Kompatibel mit Microsofts und anderen L2TP VPN-Servern."

#: properties/ppp-dialog.c:177
msgid "All Available (Default)"
msgstr "Alle verfügbaren (Vorgabe)"

#: properties/ppp-dialog.c:181
msgid "128-bit (most secure)"
