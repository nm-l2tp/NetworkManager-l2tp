#: properties/ipsec-dialog.c:574 properties/nm-l2tp-editor.c:590
msgid "Certificates (TLS)"
msgstr "Zertifikate (TLS):"

#: properties/nm-l2tp-dialog.ui:16
msgid "General"
msgstr "Allgemein"

#: properties/nm-l2tp-dialog.ui:32
msgid "_Gateway"
msgstr "_Gateway"

#: properties/nm-l2tp-dialog.ui:46
msgid ""
"L2TP server IP or name.\n"
"config: xl2tpd lns parameter"
msgstr ""
"IP-Adresse oder Name des L2TP-Servers.\n"
"config: xl2tpd lns parameter"

#: properties/nm-l2tp-dialog.ui:61
msgid "User Authentication"
msgstr "Benutzer-Authentifizierung"

#: properties/nm-l2tp-dialog.ui:77 properties/nm-l2tp-dialog.ui:577
msgid "Type"
msgstr "Art"

#: properties/nm-l2tp-dialog.ui:89 properties/nm-l2tp-dialog.ui:589
msgid "Select an authentication mode."
msgstr "Wählen Sie einen Legitimierungsmodus."

#: properties/nm-l2tp-dialog.ui:127
msgid ""
"Use down-level logon name format for user authentication purposes, i.e. "
"DOMAIN\\username, where DOMAIN is the value from this text entry box."
msgstr ""
"Verwenden Sie für die Benutzer-Authentifizierung das Anmeldeformat der "
"niedrigeren Ebene, d.h. DOMAIN\\Benutzername, wobei DOMAIN der Wert aus "
"diesem Texteingabefeld ist."

#: properties/nm-l2tp-dialog.ui:137 properties/nm-l2tp-dialog.ui:625
msgid "Sho_w password"
msgstr "Passwort _anzeigen"

#: properties/nm-l2tp-dialog.ui:154
msgid "Password passed to PPPD when prompted for it."
msgstr "Passwort, das auf Anfrage an PPPD übergeben wird."

#: properties/nm-l2tp-dialog.ui:167
msgid ""
"Username passed to PPPD when prompted for it. If omitted, use the name of "
"the system user that activates the connection.\n"
"config: ppp name parameter\n"
"config: auth-user-pass"
msgstr ""
"Benutzername, der auf Anfrage an PPPD übergeben wird. Falls leer, wird der "
"Name des Systembenutzers verwendet, der die Verbindung aktiviert.\n"
"config: ppp name parameter\n"
"config: auth-user-pass"

#: properties/nm-l2tp-dialog.ui:181
msgid "User name"
msgstr "Benutzername"

#: properties/nm-l2tp-dialog.ui:205
msgid "NT Domain"
msgstr "NT-Domäne"

#: properties/nm-l2tp-dialog.ui:308
msgid "Use L2TP _ephemeral source port"
msgstr "Ephemeren L2TP-Quellport _verwenden"

#: properties/nm-l2tp-dialog.ui:312
msgid ""
"Do not use UDP port 1701 for L2TP source port even if it is free,\n"
"will use an ephemeral port (i.e. random high port) instead.\n"
"May be required to allow multiple L2TP clients behind same NAT."
msgstr ""
"UDP-Port 1701 nicht als L2TP-Quellport verwenden, auch wenn er frei ist,\n"
"stattdessen wird ein ephemerer Port verwendet (d.h. ein zufälliger hoher "
"Port).\n"
"Kann erforderlich sein, um mehrere L2TP-Clients hinter demselben NAT "
"zuzulassen."

#: properties/nm-l2tp-dialog.ui:361
msgid "_IPsec Settings..."
msgstr "_IPsec-Einstellungen …"

#: properties/nm-l2tp-dialog.ui:406
msgid "PPP Se_ttings..."
msgstr "PPP-_Einstellungen …"

#: properties/nm-l2tp-dialog.ui:454
msgid "L2TP IPsec Options"
msgstr "Optionen für L2TP-IPsec"

#: properties/nm-l2tp-dialog.ui:469
msgid "IPsec Properties"
msgstr "IPsec-Eigenschaften"

#: properties/nm-l2tp-dialog.ui:477 properties/nm-l2tp-dialog.ui:1199
msgid "_Cancel"
msgstr "_Abbrechen"

#: properties/nm-l2tp-dialog.ui:485 properties/nm-l2tp-dialog.ui:1207
msgid "_Apply"
msgstr "_Anwenden"

#: properties/nm-l2tp-dialog.ui:539
msgid "_Enable IPsec tunnel to L2TP host"
msgstr "IPsec-Tunnel zum L2TP-Host _aktivieren"

#: properties/nm-l2tp-dialog.ui:543
msgid "config: ipsec-enabled"
msgstr "config: ipsec-enabled"

#: properties/nm-l2tp-dialog.ui:560
msgid "Machine Authentication"
msgstr "Rechner-Authentifizierung"

#: properties/nm-l2tp-dialog.ui:642
msgid ""
"Pre-shared key (PSK) secret.\n"
"config: ipsec-psk"
msgstr ""
"Geheimer vorinstallierter Schlüssel (PSK).\n"
"config: ipsec-psk"

#: properties/nm-l2tp-dialog.ui:656
msgid "Pre-shared key"
msgstr "Vorinstallierter Schlüssel"

#: properties/nm-l2tp-dialog.ui:781
msgid ""
"Optional. A list of proposals for IKE - Main Mode. The format is “enc-integ-"
"group,enc-integ-group, …”.\n"
"config: ipsec-ike <proposals>"
msgstr ""
"Optional. Eine Liste von Vorschlägen für IKE - Hauptmodus. Das Format ist "
"»enc-integ-group,enc-integ-group, …«.\n"
"config: ipsec-ike <proposals>"

#: properties/nm-l2tp-dialog.ui:794
msgid ""
"Optional. A list of proposals for ESP - Quick Mode. The format is “enc-"
"integ,enc-integ, …”.\n"
"config: ipsec-esp <proposals>"
msgstr ""
"Optional. Eine Liste von Vorschlägen für ESP - Schnellmodus. Das Format ist "
"»enc-integ,enc-integ, …«.\n"
"config: ipsec-esp <proposals>"

#: properties/nm-l2tp-dialog.ui:812
msgid ""
"How long the keying channel of a connection should last before being "
"renegotiated. \n"
"config: ipsec-ikelifetime <lifetime>"
msgstr ""
"Wie lange der Schlüsselkanal einer Verbindung bestehen soll, bevor er neu "
"ausgehandelt wird.\n"
"config: ipsec-ikelifetime <lifetime>"

#: properties/nm-l2tp-dialog.ui:829 properties/nm-l2tp-dialog.ui:869
msgid "(HH:MM)"
msgstr "(SS:MM)"

#: properties/nm-l2tp-dialog.ui:852
msgid ""
"How long a particular instance of a connection (a set of encryption/"
"authentication keys for user packets) should last, from successful "
"negotiation to expiry.\n"
"config: ipsec-salifetime <lifetime>"
msgstr ""
"Wie lange eine bestimmte Instanz einer Verbindung (ein Satz von "
"Verschlüsselungs-/Authentifizierungsschlüsseln für Benutzerpakete) bestehen "
"soll, von der erfolgreichen Aushandlung bis zum Ablauf.\n"
"config: ipsec-salifetime <lifetime>"

#: properties/nm-l2tp-dialog.ui:885
msgid "Phase1 Lifetime:"
msgstr "Phase1-Lebensdauer:"

#: properties/nm-l2tp-dialog.ui:900
msgid "Phase2 Lifetime:"
msgstr "Phase2-Lebensdauer:"

#: properties/nm-l2tp-dialog.ui:917
msgid ""
"Optional. How the IPsec server should be identified for authentication. "
"Sometimes referred to as Peer ID or Gateway ID, also referred to as rightid "
"by strongSwan, Libreswan, Openswan and FreeS/WAN. See strongSwan or "
"Libreswan documentation for leftid/rightid syntax and identity parsing.\n"
"config: ipsec-remote-id <rightid>\n"
"ipsec.secrets: <ID>"
msgstr ""
"Optional. Wie der IPsec-Server zur Authentifizierung identifiziert werden "
"soll. Dies wird manchmal als Peer-ID oder Gateway-ID bezeichnet und von "
"strongSwan, Libreswan, Openswan und FreeS/WAN auch als rightid. Siehe die "
"Dokumentation von strongSwan oder Libreswan zur Syntax von leftid/rightid "
"und zur Identitätsauswertung.\n"
"config: ipsec-remote-id <rightid>\n"
"ipsec.secrets: <ID>"

#: properties/nm-l2tp-dialog.ui:933
msgid ""
"Optional. Sometimes referred to as IPSec ID, also referred to as leftid by "
"strongSwan, Libreswan, Openswan and FreeS/WAN. See strongSwan or Libreswan "
"documentation for leftid/rightid syntax and identity parsing.\n"
"config: ipsec-group-name <leftid>"
msgstr ""
"Optional. Wird manchmal als IPSec-ID bezeichnet und von strongSwan, "
"Libreswan, Openswan und FreeS/WAN auch als leftid. Siehe die Dokumentation "
"von strongSwan oder Libreswan zur Syntax von leftid/rightid und zur "
"Identitätsauswertung.\n"
"config: ipsec-group-name <leftid>"

#: properties/nm-l2tp-dialog.ui:946
msgid "Phase1 Algorithms:"
msgstr "Phase1-Algorithmen:"

#: properties/nm-l2tp-dialog.ui:961
msgid "Phase2 Algorithms:"
msgstr "Phase2-Algorithmen:"

#: properties/nm-l2tp-dialog.ui:976
msgid "Remote ID:"
msgstr "Entfernte ID:"

#: properties/nm-l2tp-dialog.ui:991
msgid "Group Name:"
msgstr "Gruppenname:"

#: properties/nm-l2tp-dialog.ui:1029
msgid "_Enforce UDP encapsulation"
msgstr "UDP-Kapselung erzwingen"

#: properties/nm-l2tp-dialog.ui:1033
msgid ""
"Some firewalls block ESP traffic. Enforcing UDP capsulation even if no NAT "
"situation is detected might help in such cases.\n"
"config: ipsec-forceencaps <yes/no>"
msgstr ""
"Einige Firewalls blockieren ESP-Datenverkehr. Das Erzwingen von UDP-"
"Kapselung kann auch dann helfen, wenn keine NAT-Situation erkannt wird.\n"
"config: ipsec-forceencaps <yes/no>"

#: properties/nm-l2tp-dialog.ui:1048
msgid "Use IP c_ompression"
msgstr "IP-Pakete k_omprimieren"

#: properties/nm-l2tp-dialog.ui:1052
msgid ""
"IPComp compresses raw IP packets before they get encrypted. This saves some "
"bandwidth, but uses more processing power.\n"
"config: ipsec-ipcomp <yes/no>"
msgstr ""
"IPComp komprimiert rohe IP-Pakete, bevor sie verschlüsselt werden. Das spart "
"etwas Bandbreite, benötigt aber mehr Rechenleistung.\n"
"config: ipsec-ipcomp <yes/no>"

#: properties/nm-l2tp-dialog.ui:1067
msgid "Use IKEv_2 key exchange"
msgstr "IKEv_2-Schlüsselaustausch verwenden"

#: properties/nm-l2tp-dialog.ui:1071
msgid ""
"Use IKEv2 key exchange\n"
"config: ipsec-ikev2 <yes/no>"
msgstr ""
"IKEv2-Schlüsselaustausch verwenden\n"
"config: ipsec-ikev2 <yes/no>"

#: properties/nm-l2tp-dialog.ui:1086
msgid "Disable _PFS"
msgstr "_PFS deaktivieren"

#: properties/nm-l2tp-dialog.ui:1090
msgid ""
"Disable perfect forward secrecy. Enable this option only if the server "
"doesn’t support PFS.\n"
"config: ipsec-pfs <no/yes>"
msgstr ""
"Perfect Forward Secrecy deaktivieren. Aktivieren Sie diese Option nur, wenn "
"der Server PFS nicht unterstützt.\n"
"config: ipsec-pfs <no/yes>"

#: properties/nm-l2tp-dialog.ui:1109
msgid "Ad_vanced"
msgstr "Er_weitert"

#: properties/nm-l2tp-dialog.ui:1148
msgid "Default"
msgstr "Vorgabe"

#: properties/nm-l2tp-dialog.ui:1175
msgid "L2TP PPP Options"
msgstr "Optionen für L2TP-PPP"

#: properties/nm-l2tp-dialog.ui:1191
msgid "PPP Properties"
msgstr "PPP-Eigenschaften"

#: properties/nm-l2tp-dialog.ui:1268
msgid "Authentication"
msgstr "Authentifizierung"

#: properties/nm-l2tp-dialog.ui:1290
msgid "Allow the following authentication methods:"
msgstr "Die folgenden Authentifizierungsmethoden erlauben:"

#: properties/nm-l2tp-dialog.ui:1309
msgid ""
"Allow/disable authentication methods.\n"
"config: refuse-pap, refuse-chap, refuse-mschap, refuse-mschap-v2, refuse-eap"
msgstr ""
"Authentifizierungsmethoden erlauben/abschalten.\n"
"config: refuse-pap, refuse-chap, refuse-mschap, refuse-mschap-v2, refuse-eap"

#: properties/nm-l2tp-dialog.ui:1348
msgid "Security and Compression"
msgstr "Sicherheit und Komprimierung"

#: properties/nm-l2tp-dialog.ui:1375
msgid "Use _Point-to-Point encryption (MPPE)"
msgstr "_Point-to-Point Verschlüsselung (MPPE) verwenden"

#: properties/nm-l2tp-dialog.ui:1379
msgid ""
"Note: MPPE encryption is only available with MSCHAP authentication methods. "
"To enable this checkbox, select one or more of the MSCHAP authentication "
"methods: MSCHAP or MSCHAPv2."
msgstr ""
"Achtung: MPPE-Verschlüsselung ist nur mit MSCHAP-Authentifizierungsmethoden "
"verfügbar. Um dieses Ankreuzfeld zu aktivieren, wählen Sie eine oder mehrere "
"der folgenden Authentifizierungsmethoden aus: MSCHAP oder MSCHAPv2."

#: properties/nm-l2tp-dialog.ui:1405
msgid "_Security"
msgstr "_Sicherheit"

#: properties/nm-l2tp-dialog.ui:1420
msgid ""
"Require the use of MPPE, with 40/128-bit encryption or all.\n"
"config: require-mppe, require-mppe-128 or require-mppe-40"
msgstr ""
"Den Einsatz von MPPE-Verschlüsselung auf automatische Auswahl, 128-Bit oder "
"40-Bit festlegen.\n"
"config: require-mppe, require-mppe-128 oder require-mppe-40"

#: properties/nm-l2tp-dialog.ui:1445
msgid "Allow st_ateful encryption"
msgstr "St_ateful-Verschlüsselung erlauben"

#: properties/nm-l2tp-dialog.ui:1449
msgid ""
"Allow MPPE to use stateful mode. Stateless mode is still attempted first.\n"
"config: mppe-stateful (when checked)"
msgstr ""
"MPPE im Modus »stateful« erlauben. Statusloser Modus wird weiterhin zuerst "
"versucht.\n"
"config: mppe-stateful (wenn gewählt)"

#: properties/nm-l2tp-dialog.ui:1477
msgid "Allow _BSD data compression"
msgstr "_BSD-Datenkomprimierung erlauben"

#: properties/nm-l2tp-dialog.ui:1481
msgid ""
"Allow/disable BSD-Compress compression.\n"
"config: nobsdcomp (when unchecked)"
msgstr ""
"BSD-Compress Kompression erlauben/abschalten.\n"
"config: nobsdcomp (wenn abgewählt)"

#: properties/nm-l2tp-dialog.ui:1495
msgid "Allow _Deflate data compression"
msgstr "_Deflate-Datenkomprimierung erlauben"

#: properties/nm-l2tp-dialog.ui:1499
msgid ""
"Allow/disable Deflate compression.\n"
"config: nodeflate (when unchecked)"
msgstr ""
"Deflate-Kompression erlauben/abschalten.\n"
"config: nodeflate (wenn abgewählt)"

#: properties/nm-l2tp-dialog.ui:1513
msgid "Use TCP _header compression"
msgstr "TCP-_Header-Komprimierung verwenden"

#: properties/nm-l2tp-dialog.ui:1517
msgid ""
"Allow/disable Van Jacobson style TCP/IP header compression in both the "
"transmit and the receive directions.\n"
"config: novj (when unchecked)"
msgstr ""
"Van Jacobson TCP/IP Header-Kompression in Sende- und Empfangsrichtung "
"erlauben/abschalten.\n"
"config: novj (wenn abgewählt)"

#: properties/nm-l2tp-dialog.ui:1531
msgid "Use protocol _field compression negotiation"
msgstr "Aushandlung der Protokoll_feld-Komprimierung verwenden"

#: properties/nm-l2tp-dialog.ui:1535
msgid ""
"Allow protocol field compression negotiation in both the receive and the "
"transmit direction.\n"
"config: nopcomp (when unchecked)"
msgstr ""
"Aushandlung der Protokollfeld-Komprimierung in Sende- und Empfangsrichtung "
"erlauben/abschalten.\n"
"config: nopcomp (wenn abgewählt)"

#: properties/nm-l2tp-dialog.ui:1549
msgid "Use _Address/Control compression"
msgstr "_Adress-/Steuerfeld-Komprimierung verwenden"

#: properties/nm-l2tp-dialog.ui:1553
msgid ""
"Use Address/Control compression in both directions (send and receive).\n"
"config: noaccomp (when unchecked)"
msgstr ""
"Adress-/Steuerfeld-Komprimierung in beiden Richtungen (Senden und Empfangen) "
"verwenden.\n"
"config: noaccomp (wenn abgewählt)"

#: properties/nm-l2tp-dialog.ui:1589
msgid "Misc"
msgstr "Extra"

#: properties/nm-l2tp-dialog.ui:1609
msgid "Send PPP _echo packets"
msgstr "PPP-_Echo Pakete senden"

# Alternativ: Echo-Anfragen
#: properties/nm-l2tp-dialog.ui:1613
msgid ""
"Send LCP echo-requests to find out whether peer is alive.\n"
"config: lcp-echo-failure and lcp-echo-interval"
msgstr ""
"LCP Echo-Requests senden, um zu erkennen, ob der Partner reagiert.\n"
"config: lcp-echo-failure und lcp-echo-interval"

#: properties/nm-l2tp-dialog.ui:1632
msgid "_Multilink PPP MRRU:"
msgstr "_Multilink-PPP-MRRU:"

#: properties/nm-l2tp-dialog.ui:1636 properties/nm-l2tp-dialog.ui:1652
msgid ""
"Try to negotiate a PPP Multilink on a single connection.\n"
"config: mrru"
msgstr ""
"Versuchen, PPP-Multilink auf einer einzelnen Verbindung auszuhandeln.\n"
"config: mrru"

#: properties/nm-l2tp-dialog.ui:1656 properties/nm-l2tp-dialog.ui:1699
#: properties/nm-l2tp-dialog.ui:1742
